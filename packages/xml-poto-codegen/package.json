{
	"name": "@cerios/xml-poto-codegen",
	"version": "2.1.0",
	"description": "Generate TypeScript classes with xml-poto decorators from XSD schemas. CLI tool with config-based multi-XSD support.",
	"keywords": [
		"cerios",
		"code-generation",
		"codegen",
		"decorators",
		"typescript",
		"xml",
		"xml-poto",
		"xsd",
		"xsd-to-typescript"
	],
	"homepage": "https://github.com/CeriosTesting/xml-poto/tree/main/packages/xml-poto-codegen#readme",
	"bugs": {
		"url": "https://github.com/CeriosTesting/xml-poto/issues"
	},
	"license": "MIT",
	"author": "Ronald Veth - Cerios",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CeriosTesting/xml-poto.git"
	},
	"bin": {
		"xml-poto-codegen": "dist/cli.cjs"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest --run",
		"test:coverage": "vitest --coverage",
		"test:watch": "vitest --watch",
		"pack": "npm pack --pack-destination ../..",
		"compile": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^15.0.0",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"@cerios/xml-poto": "2.4.0",
		"@types/node": "^26.1.1",
		"esbuild": "^0.28.1",
		"tsdown": "^0.22.9",
		"typescript": "^7.0.2",
		"vitest": "4.1.10"
	},
	"peerDependencies": {
		"@cerios/xml-poto": "^2.4.0"
	},
	"engines": {
		"node": ">=20.19.0"
	}
}
