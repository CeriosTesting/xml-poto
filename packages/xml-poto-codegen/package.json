{
	"name": "@cerios/xml-poto-codegen",
	"version": "1.0.0",
	"description": "Generate TypeScript classes with xml-poto decorators from XSD schemas. CLI tool with config-based multi-XSD support.",
	"keywords": [
		"cerios",
		"code-generation",
		"codegen",
		"decorators",
		"typescript",
		"xml",
		"xml-poto",
		"xsd",
		"xsd-to-typescript"
	],
	"homepage": "https://github.com/CeriosTesting/xml-poto/tree/main/packages/xml-poto-codegen#readme",
	"bugs": {
		"url": "https://github.com/CeriosTesting/xml-poto/issues"
	},
	"license": "MIT",
	"author": "Ronald Veth - Cerios",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CeriosTesting/xml-poto.git"
	},
	"bin": {
		"xml-poto-codegen": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown --config-loader bundle",
		"test": "vitest --run",
		"test:coverage": "vitest --coverage",
		"test:watch": "vitest --watch",
		"pack": "npm pack --pack-destination ../..",
		"compile": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^13.1.0",
		"jiti": "^2.6.1"
	},
	"devDependencies": {
		"@cerios/xml-poto": "2.2.0",
		"@types/node": "^25.4.0",
		"oxfmt": "^0.38.0",
		"oxlint": "^1.53.0",
		"oxlint-tsgolint": "^0.16.0",
		"tsdown": "^0.21.10",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@cerios/xml-poto": "^2.2.0"
	}
}
