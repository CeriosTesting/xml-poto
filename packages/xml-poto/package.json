{
	"name": "@cerios/xml-poto",
	"version": "2.3.3",
	"description": "TypeScript XML serialization library with decorator-based metadata. Supports namespaces, custom converters, validation, wrapped/unwrapped arrays, and bidirectional XML-object mapping.",
	"keywords": [
		"bi-directional",
		"cerios",
		"converter",
		"decorators",
		"deserialization",
		"mapper",
		"metadata",
		"namespaces",
		"serialization",
		"typescript",
		"validation",
		"xbrl",
		"xml",
		"xml-parser",
		"xml-serializer",
		"xmlattribute",
		"xmlelement",
		"xmlroot"
	],
	"homepage": "https://github.com/CeriosTesting/xml-poto/tree/main/packages/xml-poto#readme",
	"bugs": {
		"url": "https://github.com/CeriosTesting/xml-poto/issues"
	},
	"license": "MIT",
	"author": "Ronald Veth - Cerios",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CeriosTesting/xml-poto.git"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown --config-loader bundle",
		"check-exports": "attw --pack .",
		"test": "vitest --run",
		"test:coverage": "vitest --coverage",
		"test:watch": "vitest --watch",
		"pack": "npm pack --pack-destination ../..",
		"compile": "tsc --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.5",
		"@types/node": "^26.1.1",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"vitest": "4.0.18"
	},
	"engines": {
		"node": ">=20.19.0"
	}
}
