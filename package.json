{
	"name": "@cerios/xml-poto",
	"version": "2.0.0",
	"description": "TypeScript XML serialization library with decorator-based metadata. Supports namespaces, custom converters, validation, wrapped/unwrapped arrays, and bidirectional XML-object mapping.",
	"keywords": [
		"bi-directional",
		"cerios",
		"converter",
		"decorators",
		"deserialization",
		"mapper",
		"metadata",
		"namespaces",
		"serialization",
		"typescript",
		"validation",
		"xbrl",
		"xml",
		"xml-parser",
		"xml-serializer",
		"xmlattribute",
		"xmlelement",
		"xmlroot"
	],
	"homepage": "https://github.com/CeriosTesting/xml-poto#readme",
	"bugs": {
		"url": "https://github.com/CeriosTesting/xml-poto/issues"
	},
	"license": "MIT",
	"author": "Ronald Veth - Cerios",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CeriosTesting/xml-poto.git"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsup",
		"changeset": "changeset",
		"check": "npm run lint && npm run format",
		"check-exports": "attw --pack .",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware --type-check",
		"lint:fix": "oxlint --type-aware --type-check --fix",
		"prepare": "husky",
		"test": "vitest --run",
		"test:coverage": "vitest --coverage",
		"test:watch": "vitest --watch",
		"update-all-packages": "npx npm-check-updates -u && npm i"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@changesets/cli": "^2.29.8",
		"@types/node": "^24.10.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"npm-check-updates": "^19.1.2",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"oxlint-tsgolint": "^0.15.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15"
	}
}
