{
	"private": true,
	"author": "Ronald Veth - Cerios",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "npm run --workspaces build",
		"changeset": "changeset",
		"compile": "npm run --workspaces compile",
		"deps:check": "syncpack lint",
		"deps:fix": "syncpack fix",
		"deps:update": "npx npm-check-updates --workspaces -u --dep prod,dev,optional,peer,packageManager --install never && npm install --workspaces",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"pack": "npm run --workspaces pack",
		"release": "changeset publish",
		"test": "npm run --workspaces test",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"npm-check-updates": "^22.2.9",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"syncpack": "^15.3.2",
		"vitest": "4.0.18"
	},
	"overrides": {
		"@arethetypeswrong/cli": "^0.18.5",
		"@types/node": "^26.1.1",
		"tsdown": "^0.22.4",
		"typescript": "^7.0.2",
		"vitest": "4.0.18"
	},
	"engines": {
		"node": ">=20.19.0"
	}
}
