{
	"private": true,
	"author": "Ronald Veth - Cerios",
	"scripts": {
		"build": "pnpm -r build",
		"changeset": "changeset",
		"compile": "pnpm -r compile",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"pack": "pnpm --filter \"*\" exec pnpm pack --pack-destination ../..",
		"release": "changeset publish --provenance",
		"test": "pnpm -r test",
		"update-deps": "pnpm update -r --latest",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "pnpm version-packages && pnpm format"
	},
	"devDependencies": {
		"@changesets/cli": "catalog:",
		"husky": "catalog:",
		"lint-staged": "catalog:",
		"npm-check-updates": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@10.6.5"
}
