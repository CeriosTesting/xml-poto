{
	"private": true,
	"author": "Ronald Veth - Cerios",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "npm run --workspaces build",
		"changeset": "changeset",
		"compile": "npm run --workspaces compile",
		"deps:check": "syncpack list-mismatches",
		"deps:fix": "syncpack fix-mismatches",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"pack": "npm run --workspaces pack",
		"release": "changeset publish --provenance",
		"test": "npm run --workspaces test",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"npm-check-updates": "^19.1.2",
		"syncpack": "^13.0.4",
		"vitest": "^4.0.15"
	},
	"overrides": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/node": "^25.3.5",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"oxlint-tsgolint": "^0.16.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.15"
	}
}
